{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@sitesbd/shared/*": ["../../packages/shared/src/*"],
      "@sitesbd/ui/*": ["../../packages/ui/src/*"],
      "@sitesbd/database/*": ["../../packages/database/src/*"]
    },
    "allowJs": true,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next.config.ts",
    "src/**/*",
    ".next/types/**/*.ts"
  ]
}
